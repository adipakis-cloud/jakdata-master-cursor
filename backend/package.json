{
  "name": "jakdata-backend",
  "version": "3.0.0",
  "description": "JAKDATA Backend API",
  "prisma": {
    "seed": "npx ts-node --transpile-only prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck",
    "dev": "npx ts-node --transpile-only src/main.ts",
    "dev:stop": "powershell -NoProfile -Command \"$c=Get-NetTCPConnection -LocalPort 3001 -ErrorAction SilentlyContinue; if($c){$c.OwningProcess|Select-Object -Unique|ForEach-Object{Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue}}\"",
    "dev:safe": "npm run dev:stop && npm run dev",
    "db:push": "prisma db push",
    "db:generate": "node scripts/clean-prisma-generated.cjs && prisma generate",
    "db:seed": "npx ts-node --transpile-only prisma/seed.ts",
    "db:seed:dev": "npx ts-node --transpile-only prisma/seed.dev.ts",
    "db:seed:jakarta": "npx ts-node --transpile-only prisma/seed.jakarta.ts",
    "seed:dapil3": "ts-node --transpile-only prisma/seed-dapil3.ts",
    "seed:warga": "npx ts-node --transpile-only prisma/seed-warga-dapil3.ts",
    "seed:koordinator": "ts-node --transpile-only prisma/seed-koordinator-dapil3.ts",
    "seed:patch-rw": "ts-node --transpile-only prisma/seed-patch-rw.ts",
    "seed:warmindo": "ts-node --transpile-only prisma/seed-warmindo.ts",
    "seed:transaksi": "ts-node --transpile-only prisma/seed-transaksi-historis.ts",
    "seed:bantuan": "ts-node --transpile-only prisma/seed-bantuan-penerima.ts",
    "seed:laporan": "ts-node --transpile-only prisma/seed-laporan.ts",
    "db:reset:dev": "npx prisma db push --accept-data-loss && npm run db:seed:dev",
    "db:reset:jakarta": "npx prisma db push --accept-data-loss && npm run db:seed:jakarta"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
