{
  "name": "jakdata-backend",
  "version": "3.0.0",
  "description": "JAKDATA Backend API",
  "scripts": {
    "dev": "npx ts-node --transpile-only src/main.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "npx ts-node --transpile-only prisma/seed.ts",
    "db:seed:dev": "npx ts-node --transpile-only prisma/seed.dev.ts",
    "db:seed:jakarta": "npx ts-node --transpile-only prisma/seed.jakarta.ts",
    "db:reset:dev": "npx prisma db push --accept-data-loss && npm run db:seed:dev",
    "db:reset:jakarta": "npx prisma db push --accept-data-loss && npm run db:seed:jakarta"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
