// ── TPS / QUICK COUNT ─────────────────────────────────────────────

model ElectionEvent {
  id               Int      @id @default(autoincrement())
  namaEvent        String   @map("nama_event") @db.VarChar(200)
  jenisEvent       String   @map("jenis_event") @db.VarChar(30)
  tanggalPemilihan DateTime @map("tanggal_pemilihan") @db.Date
  kecamatanId      Int?     @map("kecamatan_id")
  status           String   @default("persiapan") @db.VarChar(20)
  kontestan        Json     @default("[]")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  kecamatan Kecamatan?  @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  tps       Tps[]
  results   TpsResult[]

  @@index([kecamatanId])
  @@index([status])
  @@map("election_events")
}

model Tps {
  id          Int      @id @default(autoincrement())
  kodeTps     String   @map("kode_tps") @db.VarChar(20)
  electionId  Int      @map("election_id")
  rtId        Int?     @map("rt_id")
  kelurahanId Int?     @map("kelurahan_id")
  kecamatanId Int?     @map("kecamatan_id")
  alamat      String?
  jumlahDpt   Int      @default(0) @map("jumlah_dpt")
  createdAt   DateTime @default(now()) @map("created_at")

  election  ElectionEvent @relation(fields: [electionId], references: [id])
  rt        RT?           @relation(fields: [rtId], references: [id], onDelete: SetNull)
  kelurahan Kelurahan?    @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  kecamatan Kecamatan?    @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  results   TpsResult[]

  @@unique([electionId, kodeTps])
  @@index([electionId])
  @@index([rtId])
  @@index([kelurahanId])
  @@index([kecamatanId])
  @@map("tps")
}

model TpsResult {
  id             Int      @id @default(autoincrement())
  tpsId          Int      @map("tps_id")
  electionId     Int      @map("election_id")
  jumlahPengguna Int      @default(0) @map("jumlah_pengguna")
  suaraSah       Int      @default(0) @map("suara_sah")
  suaraTidakSah  Int      @default(0) @map("suara_tidak_sah")
  hasilSuara     Json     @default("{}") @map("hasil_suara")
  buktiFotoUrl   String?  @map("bukti_foto_url")
  status         String   @default("draft") @db.VarChar(20)
  inputBy        Int?     @map("input_by")
  verifiedBy     Int?     @map("verified_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tps          Tps           @relation(fields: [tpsId], references: [id])
  election     ElectionEvent @relation(fields: [electionId], references: [id])
  inputByUser  User?         @relation("TpsResultInputBy", fields: [inputBy], references: [id], onDelete: SetNull)
  verifiedUser User?         @relation("TpsResultVerifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)

  @@unique([tpsId, electionId])
  @@index([electionId])
  @@index([inputBy])
  @@index([verifiedBy])
  @@index([status])
  @@map("tps_results")
}

