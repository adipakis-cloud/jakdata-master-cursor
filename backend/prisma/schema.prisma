generator client {
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin_pusat
  admin_kota
  admin_kecamatan
  admin_kelurahan
  koordinator_kecamatan
  koordinator_kelurahan
  koordinator_rw
  koordinator_rt
  petugas_lapangan
  manager_warmindo
  kasir_warmindo
  auditor
  finance_admin
}

enum StatusEkonomi {
  sangat_miskin
  miskin
  rentan
  sedang
  mampu
}

enum UrgencyLevel {
  critical
  high
  medium
  low
}

enum ReportStatus {
  baru
  diproses
  menunggu_data
  eskalasi
  selesai
  ditolak
}

enum WarmindoStatus {
  rencana
  persiapan
  aktif
  evaluasi
  tutup
}

enum AiTaskStatus {
  pending
  processing
  done
  failed
}

enum DistribusiStatus {
  terjadwal
  diterima
  tidak_hadir
  ditolak
}

enum UmkmStatus {
  rintisan
  aktif
  berkembang
  nonaktif
}

enum OperationalAlertStatus {
  open
  acknowledged
  resolved
  dismissed
}

// ── USERS & SECURITY ─────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique @default(uuid())
  nama          String    @db.VarChar(150)
  email         String    @unique @db.VarChar(200)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  role          UserRole
  aktif         Boolean   @default(true)
  noHp          String?   @map("no_hp") @db.VarChar(20)
  lastLoginAt   DateTime? @map("last_login_at")
  loginAttempts Int       @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until")
  kotaId        Int?      @map("kota_id")
  kecamatanId   Int?      @map("kecamatan_id")
  kelurahanId   Int?      @map("kelurahan_id")
  rwId          Int?      @map("rw_id")
  rtId          Int?      @map("rt_id")
  warmindoId    Int?      @map("warmindo_id")
  kinerjaSkor        Int       @default(0) @map("kinerja_skor")
  kinerjaBintang     Int       @default(0) @map("kinerja_bintang")
  kinerjaLevel       String    @default("baru") @map("kinerja_level") @db.VarChar(20)
  lastActivityAt     DateTime? @map("last_activity_at")
  totalWargaInput    Int       @default(0) @map("total_warga_input")
  totalLaporanInput  Int       @default(0) @map("total_laporan_input")
  totalHariAktif     Int       @default(0) @map("total_hari_aktif")
  dataQualityScore   Int       @default(0) @map("data_quality_score")
  skorUpdatedAt      DateTime? @map("skor_updated_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  kota                   Kota?              @relation(fields: [kotaId], references: [id], onDelete: SetNull)
  kecamatan              Kecamatan?         @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  kelurahan              Kelurahan?         @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  rw                     RW?                @relation(fields: [rwId], references: [id], onDelete: SetNull)
  rt                     RT?                @relation(fields: [rtId], references: [id], onDelete: SetNull)
  warmindoOutlet         WarmindoOutlet?    @relation("UserWarmindoOutlet", fields: [warmindoId], references: [id], onDelete: SetNull)
  managedWarmindoOutlets WarmindoOutlet[]   @relation("WarmindoOutletManager")
  refreshTokens          RefreshToken[]
  auditLogs              AuditLog[]
  createdWarga           Warga[]            @relation("WargaCreatedBy")
  createdLaporanWarga    LaporanWarga[]     @relation("LaporanCreatedBy")
  assignedLaporanWarga   LaporanWarga[]     @relation("LaporanAssignedTo")
  aiTasks                AiTask[]
  designJobs             DesignJob[]
  videoJobs              VideoJob[]         @relation("VideoJobCreatedBy")
  uploadedFiles          File[]             @relation("FileUploadedBy")
  inputTpsResults        TpsResult[]        @relation("TpsResultInputBy")
  verifiedTpsResults     TpsResult[]        @relation("TpsResultVerifiedBy")
  createdUmkm            Umkm[]             @relation("UmkmCreatedBy")
  createdAlerts          OperationalAlert[] @relation("OperationalAlertCreatedBy")
  acknowledgedAlerts     OperationalAlert[] @relation("OperationalAlertAcknowledgedBy")
  resolvedAlerts         OperationalAlert[] @relation("OperationalAlertResolvedBy")

  @@index([email])
  @@index([role])
  @@index([kotaId])
  @@index([kecamatanId])
  @@index([kelurahanId])
  @@index([rwId])
  @@index([rtId])
  @@index([warmindoId])
  @@index([role, kecamatanId])
  @@index([role, kelurahanId])
  @@index([role, rtId])
  @@map("users")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   Int?     @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ── WILAYAH ──────────────────────────────────────────────────────

model Provinsi {
  id        Int      @id @default(autoincrement())
  nama      String   @unique @db.VarChar(100)
  kode      String   @unique @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")
  kota      Kota[]

  @@index([nama])
  @@map("provinsi")
}

model Kota {
  id         Int         @id @default(autoincrement())
  provinsiId Int         @map("provinsi_id")
  nama       String      @db.VarChar(100)
  kode       String      @unique @db.VarChar(10)
  tipe       String      @default("kota") @db.VarChar(20)
  createdAt  DateTime    @default(now()) @map("created_at")
  provinsi   Provinsi    @relation(fields: [provinsiId], references: [id])
  kecamatan  Kecamatan[]
  users      User[]

  @@unique([provinsiId, nama])
  @@index([provinsiId])
  @@index([tipe, provinsiId])
  @@map("kota")
}

model Kecamatan {
  id        Int             @id @default(autoincrement())
  kotaId    Int             @map("kota_id")
  nama      String          @db.VarChar(100)
  kode      String?         @db.VarChar(15)
  createdAt DateTime        @default(now()) @map("created_at")
  kota      Kota            @relation(fields: [kotaId], references: [id])
  kelurahan Kelurahan[]
  users     User[]
  laporan   LaporanWarga[]
  tps       Tps[]
  elections ElectionEvent[]

  @@unique([kotaId, nama])
  @@index([kotaId])
  @@index([kode])
  @@map("kecamatan")
}

model Kelurahan {
  id          Int              @id @default(autoincrement())
  kecamatanId Int              @map("kecamatan_id")
  nama        String           @db.VarChar(100)
  kode        String?          @db.VarChar(15)
  kodePos     String?          @map("kode_pos") @db.VarChar(10)
  createdAt   DateTime         @default(now()) @map("created_at")
  kecamatan   Kecamatan        @relation(fields: [kecamatanId], references: [id])
  rw          RW[]
  users       User[]
  laporan     LaporanWarga[]
  warmindo    WarmindoOutlet[]
  tps         Tps[]
  umkm        Umkm[]

  @@unique([kecamatanId, nama])
  @@index([kecamatanId])
  @@index([kode])
  @@map("kelurahan")
}

model RW {
  id          Int       @id @default(autoincrement())
  kelurahanId Int       @map("kelurahan_id")
  nomor       String    @db.VarChar(5)
  namaKetua   String?   @map("nama_ketua") @db.VarChar(150)
  noHpKetua   String?   @map("no_hp_ketua") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  kelurahan   Kelurahan @relation(fields: [kelurahanId], references: [id])
  rt          RT[]
  users       User[]

  @@unique([kelurahanId, nomor])
  @@index([kelurahanId])
  @@index([kelurahanId, nomor])
  @@map("rw")
}

model RT {
  id          Int               @id @default(autoincrement())
  rwId        Int               @map("rw_id")
  nomor       String            @db.VarChar(5)
  namaKetua   String?           @map("nama_ketua") @db.VarChar(150)
  noHpKetua   String?           @map("no_hp_ketua") @db.VarChar(20)
  jumlahKk    Int               @default(0) @map("jumlah_kk")
  targetWarga Int               @default(10) @map("target_warga")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  rw          RW                @relation(fields: [rwId], references: [id])
  warga       Warga[]
  keluarga    Keluarga[]
  users       User[]
  laporan     LaporanWarga[]
  bantuan     BantuanPenerima[]
  warmindo    WarmindoOutlet[]
  tps         Tps[]
  umkm        Umkm[]

  @@unique([rwId, nomor])
  @@index([rwId])
  @@index([rwId, nomor])
  @@map("rt")
}

// ── WARGA ─────────────────────────────────────────────────────────

model Warga {
  id              Int            @id @default(autoincrement())
  uuid            String         @unique @default(uuid())
  rtId            Int            @map("rt_id")
  kkId            Int?           @map("kk_id")
  nama            String         @db.VarChar(150)
  nikHash         String?        @map("nik_hash") @db.VarChar(64)
  nikEncrypted    String?        @map("nik_encrypted")
  noHp            String?        @map("no_hp") @db.VarChar(20)
  jenisKelamin    String?        @map("jenis_kelamin") @db.VarChar(1)
  tanggalLahir    DateTime?      @map("tanggal_lahir") @db.Date
  alamat          String?
  pekerjaan       String?        @db.VarChar(100)
  penghasilanEst  Float?         @map("penghasilan_est")
  statusEkonomi   StatusEkonomi? @map("status_ekonomi")
  kemampuanKerja  Boolean        @default(true) @map("kemampuan_kerja")
  kebutuhanKhusus String?        @map("kebutuhan_khusus")
  kategori        String         @default("warga_biasa") @db.VarChar(30)
  diverifikasi    Boolean        @default(false)
  catatan         String?
  fotoUrl         String?        @map("foto_url")
  deletedAt       DateTime?      @map("deleted_at")
  createdBy       Int?           @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  rt            RT        @relation(fields: [rtId], references: [id])
  keluarga      Keluarga? @relation(fields: [kkId], references: [id], onDelete: SetNull)
  createdByUser User?     @relation("WargaCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  umkm          Umkm[]

  @@index([rtId])
  @@index([kkId])
  @@index([createdBy])
  @@index([nikHash])
  @@index([nama])
  @@index([deletedAt])
  @@index([rtId, deletedAt])
  @@index([rtId, createdAt(sort: Desc)])
  @@index([statusEkonomi, rtId])
  @@map("warga")
}

model Keluarga {
  id                   Int            @id @default(autoincrement())
  rtId                 Int            @map("rt_id")
  namaKepala           String         @map("nama_kepala") @db.VarChar(150)
  noKk                 String?        @unique @map("no_kk") @db.VarChar(20)
  noHpKepala           String?        @map("no_hp_kepala") @db.VarChar(20)
  jumlahAnggota        Int            @default(1) @map("jumlah_anggota")
  jumlahTanggungan     Int            @default(0) @map("jumlah_tanggungan")
  statusRumah          String?        @map("status_rumah") @db.VarChar(30)
  statusEkonomi        StatusEkonomi? @map("status_ekonomi")
  totalPenghasilan     Float?         @map("total_penghasilan")
  skorPrioritasBantuan Float?         @map("skor_prioritas_bantuan")
  kategoriBantuan      String         @default("normal") @map("kategori_bantuan") @db.VarChar(30)
  terdaftarProgram     String[]       @default([]) @map("terdaftar_program")
  catatan              String?
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  rt              RT                @relation(fields: [rtId], references: [id])
  warga           Warga[]
  bantuanPenerima BantuanPenerima[]

  @@index([rtId])
  @@index([skorPrioritasBantuan(sort: Desc)])
  @@index([rtId, kategoriBantuan])
  @@index([rtId, createdAt(sort: Desc)])
  @@map("keluarga")
}

model Umkm {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(uuid())
  kodeUmkm        String     @unique @map("kode_umkm") @db.VarChar(30)
  namaUsaha       String     @map("nama_usaha") @db.VarChar(200)
  pemilikNama     String     @map("pemilik_nama") @db.VarChar(150)
  wargaId         Int?       @map("warga_id")
  rtId            Int?       @map("rt_id")
  kelurahanId     Int?       @map("kelurahan_id")
  kategori        String     @db.VarChar(50)
  produkUtama     String?    @map("produk_utama") @db.VarChar(200)
  status          UmkmStatus @default(rintisan)
  omzetBulananEst Float?     @map("omzet_bulanan_est")
  jumlahKaryawan  Int        @default(0) @map("jumlah_karyawan")
  noHp            String?    @map("no_hp") @db.VarChar(20)
  alamat          String?
  catatan         String?
  aktif           Boolean    @default(true)
  createdBy       Int?       @map("created_by")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  warga         Warga?     @relation(fields: [wargaId], references: [id], onDelete: SetNull)
  rt            RT?        @relation(fields: [rtId], references: [id], onDelete: SetNull)
  kelurahan     Kelurahan? @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  createdByUser User?      @relation("UmkmCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([kategori])
  @@index([aktif])
  @@index([rtId])
  @@index([kelurahanId])
  @@index([wargaId])
  @@index([createdBy])
  @@map("umkm")
}

// ── LAPORAN WARGA ─────────────────────────────────────────────────

model LaporanWarga {
  id               Int          @id @default(autoincrement())
  kodeLaporan      String       @unique @map("kode_laporan") @db.VarChar(20)
  channelType      String       @map("channel_type") @db.VarChar(20)
  namaPelapor      String?      @map("nama_pelapor") @db.VarChar(150)
  noHpPelapor      String?      @map("no_hp_pelapor") @db.VarChar(20)
  isiLaporan       String
  kategori         String       @db.VarChar(30)
  subkategori      String?      @db.VarChar(50)
  urgencyLevel     UrgencyLevel @default(medium) @map("urgency_level")
  lokasiText       String?      @map("lokasi_text")
  rtId             Int?         @map("rt_id")
  kelurahanId      Int?         @map("kelurahan_id")
  kecamatanId      Int?         @map("kecamatan_id")
  isEmergency      Boolean      @default(false) @map("is_emergency")
  status           ReportStatus @default(baru)
  aiSummary        String?      @map("ai_summary")
  aiRecommendation String?      @map("ai_recommendation")
  lampiranUrls     String[]     @default([]) @map("lampiran_urls")
  assignedTo       Int?         @map("assigned_to")
  slaDeadline      DateTime?    @map("sla_deadline")
  resolvedAt       DateTime?    @map("resolved_at")
  createdBy        Int?         @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  rt             RT?              @relation(fields: [rtId], references: [id], onDelete: SetNull)
  kelurahan      Kelurahan?       @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  kecamatan      Kecamatan?       @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  assignedToUser User?            @relation("LaporanAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  createdByUser  User?            @relation("LaporanCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  messages       LaporanMessage[]

  @@index([status])
  @@index([urgencyLevel])
  @@index([status, urgencyLevel])
  @@index([isEmergency])
  @@index([rtId])
  @@index([kelurahanId])
  @@index([kecamatanId])
  @@index([assignedTo])
  @@index([createdBy])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([rtId, status])
  @@index([kelurahanId, status])
  @@index([kecamatanId, status])
  @@map("laporan_warga")
}

model LaporanMessage {
  id             Int      @id @default(autoincrement())
  laporanId      Int      @map("laporan_id")
  senderType     String   @map("sender_type") @db.VarChar(20)
  messageText    String   @map("message_text")
  attachmentUrls String[] @default([]) @map("attachment_urls")
  isInternal     Boolean  @default(false) @map("is_internal")
  createdAt      DateTime @default(now()) @map("created_at")

  laporan LaporanWarga @relation(fields: [laporanId], references: [id])

  @@index([laporanId])
  @@map("laporan_messages")
}

model OperationalAlert {
  id             Int                    @id @default(autoincrement())
  uuid           String                 @unique @default(uuid())
  kodeAlert      String                 @unique @map("kode_alert") @db.VarChar(30)
  kategori       String                 @db.VarChar(50)
  severity       UrgencyLevel           @default(medium)
  status         OperationalAlertStatus @default(open)
  judul          String                 @db.VarChar(200)
  deskripsi      String
  source         String                 @default("seed") @db.VarChar(50)
  entityType     String?                @map("entity_type") @db.VarChar(50)
  entityId       Int?                   @map("entity_id")
  wilayahLevel   String?                @map("wilayah_level") @db.VarChar(20)
  wilayahId      Int?                   @map("wilayah_id")
  metadata       Json                   @default("{}")
  createdBy      Int?                   @map("created_by")
  acknowledgedBy Int?                   @map("acknowledged_by")
  acknowledgedAt DateTime?              @map("acknowledged_at")
  resolvedBy     Int?                   @map("resolved_by")
  resolvedAt     DateTime?              @map("resolved_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  createdByUser      User? @relation("OperationalAlertCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  acknowledgedByUser User? @relation("OperationalAlertAcknowledgedBy", fields: [acknowledgedBy], references: [id], onDelete: SetNull)
  resolvedByUser     User? @relation("OperationalAlertResolvedBy", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
  @@index([kategori])
  @@index([entityType, entityId])
  @@index([wilayahLevel, wilayahId])
  @@index([createdAt(sort: Desc)])
  @@index([createdBy])
  @@index([acknowledgedBy])
  @@index([resolvedBy])
  @@index([severity, status])
  @@index([wilayahLevel, wilayahId, status])
  @@map("operational_alerts")
}

model TerritorialSocialProfile {
  id                 Int      @id @default(autoincrement())
  kodeProfile        String   @unique @map("kode_profile") @db.VarChar(40)
  wilayahLevel       String   @map("wilayah_level") @db.VarChar(20)
  wilayahId          Int      @map("wilayah_id")
  label              String   @db.VarChar(200)
  densityLevel       String   @map("density_level") @db.VarChar(30)
  povertyRisk        String   @map("poverty_risk") @db.VarChar(30)
  activeStatus       String   @map("active_status") @db.VarChar(30)
  vulnerableFamilies Int      @default(0) @map("vulnerable_families")
  elderlyCount       Int      @default(0) @map("elderly_count")
  childrenCount      Int      @default(0) @map("children_count")
  disabilityCount    Int      @default(0) @map("disability_count")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([wilayahLevel, wilayahId])
  @@index([povertyRisk])
  @@index([activeStatus])
  @@map("territorial_social_profiles")
}

model TerritorialEconomicSnapshot {
  id                  Int      @id @default(autoincrement())
  kodeSnapshot        String   @unique @map("kode_snapshot") @db.VarChar(40)
  wilayahLevel        String   @map("wilayah_level") @db.VarChar(20)
  wilayahId           Int      @map("wilayah_id")
  unemploymentRate    Float    @map("unemployment_rate")
  avgIncome           Float    @map("avg_income")
  umkmCount           Int      @default(0) @map("umkm_count")
  informalWorkerRate  Float    @map("informal_worker_rate")
  economicStressScore Float    @map("economic_stress_score")
  capturedAt          DateTime @default(now()) @map("captured_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([wilayahLevel, wilayahId])
  @@index([economicStressScore])
  @@map("territorial_economic_snapshots")
}

model FoodSecuritySnapshot {
  id               Int      @id @default(autoincrement())
  kodeSnapshot     String   @unique @map("kode_snapshot") @db.VarChar(40)
  wilayahLevel     String   @map("wilayah_level") @db.VarChar(20)
  wilayahId        Int      @map("wilayah_id")
  foodRiskScore    Float    @map("food_risk_score")
  mealGapFamilies  Int      @default(0) @map("meal_gap_families")
  staplePriceIndex Float    @map("staple_price_index")
  notes            String?
  capturedAt       DateTime @default(now()) @map("captured_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([wilayahLevel, wilayahId])
  @@index([foodRiskScore])
  @@map("food_security_snapshots")
}

model TerritorialStressSignal {
  id           Int      @id @default(autoincrement())
  kodeSignal   String   @unique @map("kode_signal") @db.VarChar(40)
  wilayahLevel String   @map("wilayah_level") @db.VarChar(20)
  wilayahId    Int      @map("wilayah_id")
  signalType   String   @map("signal_type") @db.VarChar(50)
  severity     String   @default("medium") @db.VarChar(20)
  score        Float    @default(0)
  description  String
