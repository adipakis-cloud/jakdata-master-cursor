  wilayahId    Int?     @map("wilayah_id")
  tanggal      DateTime @default(now())
  ringkasan    String
  temuan       Json     @default("[]")
  rekomendasi  Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tipe])
  @@index([createdAt(sort: Desc)])
  @@map("ai_reports")
}

// -----------------------------------------------------------------
