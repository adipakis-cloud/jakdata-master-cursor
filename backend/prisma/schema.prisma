model File {
  id           Int            @id @default(autoincrement())
  uuid         String         @unique @default(uuid())
  originalName String         @map("original_name") @db.VarChar(255)
  storedName   String         @map("stored_name") @db.VarChar(255)
  mimeType     String         @map("mime_type") @db.VarChar(100)
  sizeBytes    Int            @map("size_bytes")
  storagePath  String         @map("storage_path")
  visibility   FileVisibility @default(private)
  isPublic     Boolean        @default(false) @map("is_public")
  entityType   String?        @map("entity_type") @db.VarChar(80)
  entityId     Int?           @map("entity_id")
  uploadedBy   Int?           @map("uploaded_by")
  checksum     String?        @db.VarChar(128)
  createdAt    DateTime       @default(now()) @map("created_at")

  uploader User? @relation("FileUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@map("files")
}

model DesignJob {
