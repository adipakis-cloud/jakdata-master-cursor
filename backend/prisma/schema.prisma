  sangat_miskin
  miskin
  rentan
  sedang
  mampu
}

enum UrgencyLevel {
  critical
  high
  medium
  low
}

enum ReportStatus {
  baru
  diproses
  menunggu_data
  eskalasi
  selesai
  ditolak
}

enum WarmindoStatus {
  rencana
  persiapan
  aktif
  evaluasi
  renovasi
  tutup
}

