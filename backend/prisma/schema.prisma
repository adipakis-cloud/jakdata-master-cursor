  status           AiTaskStatus @default(pending)
  createdBy        Int?         @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at")

  createdByUser User? @relation("DesignJobCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("design_jobs")
}

model VideoJob {
  id          Int          @id @default(autoincrement())
  judul       String       @db.VarChar(200)
  script      String
  heygenJobId String?      @map("heygen_job_id")
  videoUrl    String?      @map("video_url")
  status      AiTaskStatus @default(pending)
  createdBy   Int?         @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("video_jobs")
}

model ElectionEvent {
  id               Int      @id @default(autoincrement())
  namaEvent        String   @map("nama_event") @db.VarChar(200)
  jenisEvent       String   @map("jenis_event") @db.VarChar(40)
  tanggalPemilihan DateTime @map("tanggal_pemilihan") @db.Date
  kecamatanId      Int?     @map("kecamatan_id")
  status           String   @default("persiapan") @db.VarChar(30)
  kontestan        Json     @default("[]")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tps     Tps[]
  results TpsResult[]

  @@index([status])
  @@map("election_events")
}

model Tps {
  id          Int      @id @default(autoincrement())
  kodeTps     String   @map("kode_tps") @db.VarChar(30)
  electionId  Int      @map("election_id")
  rtId        Int?     @map("rt_id")
  kelurahanId Int?     @map("kelurahan_id")
  kecamatanId Int?     @map("kecamatan_id")
  alamat      String?
  jumlahDpt   Int      @default(0) @map("jumlah_dpt")
  createdAt   DateTime @default(now()) @map("created_at")

  election ElectionEvent @relation(fields: [electionId], references: [id], onDelete: Cascade)
  results  TpsResult[]

  @@unique([electionId, kodeTps])
  @@index([electionId])
  @@index([kelurahanId])
  @@map("tps")
}

model TpsResult {
  id             Int      @id @default(autoincrement())
  tpsId          Int      @map("tps_id")
  electionId     Int      @map("election_id")
  jumlahPengguna Int      @default(0) @map("jumlah_pengguna")
  suaraSah       Int      @default(0) @map("suara_sah")
  suaraTidakSah  Int      @default(0) @map("suara_tidak_sah")
  hasilSuara     Json     @default("{}") @map("hasil_suara")
  buktiFotoUrl   String?  @map("bukti_foto_url")
  status         String   @default("draft") @db.VarChar(30)
  inputBy        Int?     @map("input_by")
  verifiedBy     Int?     @map("verified_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tps      Tps           @relation(fields: [tpsId], references: [id], onDelete: Cascade)
  election ElectionEvent @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@unique([tpsId, electionId])
  @@index([electionId])
  @@index([status])
  @@map("tps_results")
}

model PublicOfficial {
