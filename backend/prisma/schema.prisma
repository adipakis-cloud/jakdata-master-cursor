generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin_pusat
  admin_kota
  admin_kecamatan
  admin_kelurahan
  koordinator_kecamatan
  koordinator_kelurahan
  koordinator_rw
  koordinator_rt
  petugas_lapangan
  manager_warmindo
  kasir_warmindo
  auditor
  finance_admin
}

enum StatusEkonomi {
  sangat_miskin
  miskin
  rentan
  sedang
  mampu
}

enum UrgencyLevel {
  critical
  high
  medium
  low
}

enum ReportStatus {
  baru
  diproses
  menunggu_data
  eskalasi
  selesai
  ditolak
}

enum WarmindoStatus {
  rencana
  persiapan
  aktif
  evaluasi
  tutup
}

enum AiTaskStatus {
  pending
  processing
  done
  failed
}

enum DistribusiStatus {
  terjadwal
  diterima
  tidak_hadir
  ditolak
}

enum UmkmStatus {
  rintisan
  aktif
  berkembang
  nonaktif
}

enum OperationalAlertStatus {
  open
  acknowledged
  resolved
  dismissed
}

// ── USERS & SECURITY ─────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique @default(uuid())
  nama          String    @db.VarChar(150)
  email         String    @unique @db.VarChar(200)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  role          UserRole
  aktif         Boolean   @default(true)
  noHp          String?   @map("no_hp") @db.VarChar(20)
  lastLoginAt   DateTime? @map("last_login_at")
  loginAttempts Int       @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until")
  kotaId        Int?      @map("kota_id")
  kecamatanId   Int?      @map("kecamatan_id")
  kelurahanId   Int?      @map("kelurahan_id")
  rwId          Int?      @map("rw_id")
  rtId          Int?      @map("rt_id")
  warmindoId    Int?      @map("warmindo_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  kota                   Kota?              @relation(fields: [kotaId], references: [id], onDelete: SetNull)
  kecamatan              Kecamatan?         @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  kelurahan              Kelurahan?         @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  rw                     RW?                @relation(fields: [rwId], references: [id], onDelete: SetNull)
  rt                     RT?                @relation(fields: [rtId], references: [id], onDelete: SetNull)
  warmindoOutlet         WarmindoOutlet?    @relation("UserWarmindoOutlet", fields: [warmindoId], references: [id], onDelete: SetNull)
  managedWarmindoOutlets WarmindoOutlet[]   @relation("WarmindoOutletManager")
  refreshTokens          RefreshToken[]
  auditLogs              AuditLog[]
  createdWarga           Warga[]            @relation("WargaCreatedBy")
  createdLaporanWarga    LaporanWarga[]     @relation("LaporanCreatedBy")
  assignedLaporanWarga   LaporanWarga[]     @relation("LaporanAssignedTo")
  aiTasks                AiTask[]
  designJobs             DesignJob[]
  videoJobs              VideoJob[]         @relation("VideoJobCreatedBy")
  uploadedFiles          File[]             @relation("FileUploadedBy")
  inputTpsResults        TpsResult[]        @relation("TpsResultInputBy")
  verifiedTpsResults     TpsResult[]        @relation("TpsResultVerifiedBy")
  createdUmkm            Umkm[]             @relation("UmkmCreatedBy")
  createdAlerts          OperationalAlert[] @relation("OperationalAlertCreatedBy")
  acknowledgedAlerts     OperationalAlert[] @relation("OperationalAlertAcknowledgedBy")
  resolvedAlerts         OperationalAlert[] @relation("OperationalAlertResolvedBy")

  @@index([email])
  @@index([role])
  @@index([kotaId])
  @@index([kecamatanId])
  @@index([kelurahanId])
  @@index([rwId])
  @@index([rtId])
  @@index([warmindoId])
  @@map("users")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   Int?     @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ── WILAYAH ──────────────────────────────────────────────────────

model Provinsi {
  id        Int      @id @default(autoincrement())
  nama      String   @unique @db.VarChar(100)
  kode      String   @unique @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")
  kota      Kota[]

  @@map("provinsi")
}

model Kota {
  id         Int         @id @default(autoincrement())
  provinsiId Int         @map("provinsi_id")
  nama       String      @db.VarChar(100)
  kode       String      @unique @db.VarChar(10)
  tipe       String      @default("kota") @db.VarChar(20)
  createdAt  DateTime    @default(now()) @map("created_at")
  provinsi   Provinsi    @relation(fields: [provinsiId], references: [id])
  kecamatan  Kecamatan[]
  users      User[]

  @@unique([provinsiId, nama])
  @@index([provinsiId])
  @@map("kota")
}

model Kecamatan {
  id        Int             @id @default(autoincrement())
  kotaId    Int             @map("kota_id")
  nama      String          @db.VarChar(100)
  kode      String?         @db.VarChar(15)
  createdAt DateTime        @default(now()) @map("created_at")
  kota      Kota            @relation(fields: [kotaId], references: [id])
  kelurahan Kelurahan[]
  users     User[]
  laporan   LaporanWarga[]
  tps       Tps[]
  elections ElectionEvent[]

  @@unique([kotaId, nama])
  @@index([kotaId])
  @@map("kecamatan")
}

model Kelurahan {
  id          Int              @id @default(autoincrement())
  kecamatanId Int              @map("kecamatan_id")
  nama        String           @db.VarChar(100)
  kode        String?          @db.VarChar(15)
  kodePos     String?          @map("kode_pos") @db.VarChar(10)
  createdAt   DateTime         @default(now()) @map("created_at")
  kecamatan   Kecamatan        @relation(fields: [kecamatanId], references: [id])
  rw          RW[]
  users       User[]
  laporan     LaporanWarga[]
  warmindo    WarmindoOutlet[]
  tps         Tps[]
  umkm        Umkm[]

  @@unique([kecamatanId, nama])
  @@index([kecamatanId])
  @@map("kelurahan")
}

model RW {
  id          Int       @id @default(autoincrement())
  kelurahanId Int       @map("kelurahan_id")
  nomor       String    @db.VarChar(5)
  namaKetua   String?   @map("nama_ketua") @db.VarChar(150)
  noHpKetua   String?   @map("no_hp_ketua") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  kelurahan   Kelurahan @relation(fields: [kelurahanId], references: [id])
  rt          RT[]
  users       User[]

  @@unique([kelurahanId, nomor])
  @@index([kelurahanId])
  @@map("rw")
}

model RT {
  id          Int               @id @default(autoincrement())
  rwId        Int               @map("rw_id")
  nomor       String            @db.VarChar(5)
  namaKetua   String?           @map("nama_ketua") @db.VarChar(150)
  noHpKetua   String?           @map("no_hp_ketua") @db.VarChar(20)
  jumlahKk    Int               @default(0) @map("jumlah_kk")
  targetWarga Int               @default(10) @map("target_warga")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  rw          RW                @relation(fields: [rwId], references: [id])
  warga       Warga[]
  keluarga    Keluarga[]
  users       User[]
  laporan     LaporanWarga[]
  bantuan     BantuanPenerima[]
  warmindo    WarmindoOutlet[]
  tps         Tps[]
  umkm        Umkm[]

  @@unique([rwId, nomor])
  @@index([rwId])
  @@map("rt")
}

// ── WARGA ─────────────────────────────────────────────────────────

model Warga {
  id              Int            @id @default(autoincrement())
  uuid            String         @unique @default(uuid())
  rtId            Int            @map("rt_id")
  kkId            Int?           @map("kk_id")
  nama            String         @db.VarChar(150)
  nikHash         String?        @map("nik_hash") @db.VarChar(64)
  nikEncrypted    String?        @map("nik_encrypted")
  noHp            String?        @map("no_hp") @db.VarChar(20)
  jenisKelamin    String?        @map("jenis_kelamin") @db.VarChar(1)
  tanggalLahir    DateTime?      @map("tanggal_lahir") @db.Date
  alamat          String?
  pekerjaan       String?        @db.VarChar(100)
  penghasilanEst  Float?         @map("penghasilan_est")
  statusEkonomi   StatusEkonomi? @map("status_ekonomi")
  kemampuanKerja  Boolean        @default(true) @map("kemampuan_kerja")
  kebutuhanKhusus String?        @map("kebutuhan_khusus")
  kategori        String         @default("warga_biasa") @db.VarChar(30)
  diverifikasi    Boolean        @default(false)
  catatan         String?
  fotoUrl         String?        @map("foto_url")
  deletedAt       DateTime?      @map("deleted_at")
  createdBy       Int?           @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  rt            RT        @relation(fields: [rtId], references: [id])
  keluarga      Keluarga? @relation(fields: [kkId], references: [id], onDelete: SetNull)
  createdByUser User?     @relation("WargaCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  umkm          Umkm[]

  @@index([rtId])
  @@index([kkId])
  @@index([createdBy])
  @@index([nikHash])
  @@index([nama])
  @@index([deletedAt])
  @@map("warga")
}

model Keluarga {
  id                   Int            @id @default(autoincrement())
  rtId                 Int            @map("rt_id")
  namaKepala           String         @map("nama_kepala") @db.VarChar(150)
  noKk                 String?        @unique @map("no_kk") @db.VarChar(20)
  noHpKepala           String?        @map("no_hp_kepala") @db.VarChar(20)
  jumlahAnggota        Int            @default(1) @map("jumlah_anggota")
  jumlahTanggungan     Int            @default(0) @map("jumlah_tanggungan")
  statusRumah          String?        @map("status_rumah") @db.VarChar(30)
  statusEkonomi        StatusEkonomi? @map("status_ekonomi")
  totalPenghasilan     Float?         @map("total_penghasilan")
  skorPrioritasBantuan Float?         @map("skor_prioritas_bantuan")
  kategoriBantuan      String         @default("normal") @map("kategori_bantuan") @db.VarChar(30)
  terdaftarProgram     String[]       @default([]) @map("terdaftar_program")
  catatan              String?
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  rt              RT                @relation(fields: [rtId], references: [id])
  warga           Warga[]
  bantuanPenerima BantuanPenerima[]

  @@index([rtId])
  @@index([skorPrioritasBantuan(sort: Desc)])
  @@map("keluarga")
}

model Umkm {
  id              Int        @id @default(autoincrement())
  uuid            String     @unique @default(uuid())
  kodeUmkm        String     @unique @map("kode_umkm") @db.VarChar(30)
  namaUsaha       String     @map("nama_usaha") @db.VarChar(200)
  pemilikNama     String     @map("pemilik_nama") @db.VarChar(150)
  wargaId         Int?       @map("warga_id")
  rtId            Int?       @map("rt_id")
  kelurahanId     Int?       @map("kelurahan_id")
  kategori        String     @db.VarChar(50)
  produkUtama     String?    @map("produk_utama") @db.VarChar(200)
  status          UmkmStatus @default(rintisan)
  omzetBulananEst Float?     @map("omzet_bulanan_est")
  jumlahKaryawan  Int        @default(0) @map("jumlah_karyawan")
  noHp            String?    @map("no_hp") @db.VarChar(20)
  alamat          String?
  catatan         String?
  aktif           Boolean    @default(true)
  createdBy       Int?       @map("created_by")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  warga         Warga?     @relation(fields: [wargaId], references: [id], onDelete: SetNull)
  rt            RT?        @relation(fields: [rtId], references: [id], onDelete: SetNull)
  kelurahan     Kelurahan? @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  createdByUser User?      @relation("UmkmCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([kategori])
  @@index([aktif])
  @@index([rtId])
  @@index([kelurahanId])
  @@index([wargaId])
  @@index([createdBy])
  @@map("umkm")
}

// ── LAPORAN WARGA ─────────────────────────────────────────────────

model LaporanWarga {
  id               Int          @id @default(autoincrement())
  kodeLaporan      String       @unique @map("kode_laporan") @db.VarChar(20)
  channelType      String       @map("channel_type") @db.VarChar(20)
  namaPelapor      String?      @map("nama_pelapor") @db.VarChar(150)
  noHpPelapor      String?      @map("no_hp_pelapor") @db.VarChar(20)
  isiLaporan       String
  kategori         String       @db.VarChar(30)
  subkategori      String?      @db.VarChar(50)
  urgencyLevel     UrgencyLevel @default(medium) @map("urgency_level")
  lokasiText       String?      @map("lokasi_text")
  rtId             Int?         @map("rt_id")
  kelurahanId      Int?         @map("kelurahan_id")
  kecamatanId      Int?         @map("kecamatan_id")
  isEmergency      Boolean      @default(false) @map("is_emergency")
  status           ReportStatus @default(baru)
  aiSummary        String?      @map("ai_summary")
  aiRecommendation String?      @map("ai_recommendation")
  lampiranUrls     String[]     @default([]) @map("lampiran_urls")
  assignedTo       Int?         @map("assigned_to")
  slaDeadline      DateTime?    @map("sla_deadline")
  resolvedAt       DateTime?    @map("resolved_at")
  createdBy        Int?         @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  rt             RT?              @relation(fields: [rtId], references: [id], onDelete: SetNull)
  kelurahan      Kelurahan?       @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  kecamatan      Kecamatan?       @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  assignedToUser User?            @relation("LaporanAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  createdByUser  User?            @relation("LaporanCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  messages       LaporanMessage[]

  @@index([status])
  @@index([urgencyLevel])
  @@index([status, urgencyLevel])
  @@index([isEmergency])
  @@index([rtId])
  @@index([kelurahanId])
  @@index([kecamatanId])
  @@index([assignedTo])
  @@index([createdBy])
  @@index([createdAt(sort: Desc)])
  @@map("laporan_warga")
}

model LaporanMessage {
  id             Int      @id @default(autoincrement())
  laporanId      Int      @map("laporan_id")
  senderType     String   @map("sender_type") @db.VarChar(20)
  messageText    String   @map("message_text")
  attachmentUrls String[] @default([]) @map("attachment_urls")
  isInternal     Boolean  @default(false) @map("is_internal")
  createdAt      DateTime @default(now()) @map("created_at")

  laporan LaporanWarga @relation(fields: [laporanId], references: [id])

  @@index([laporanId])
  @@map("laporan_messages")
}

model OperationalAlert {
  id             Int                    @id @default(autoincrement())
  uuid           String                 @unique @default(uuid())
  kodeAlert      String                 @unique @map("kode_alert") @db.VarChar(30)
  kategori       String                 @db.VarChar(50)
  severity       UrgencyLevel           @default(medium)
  status         OperationalAlertStatus @default(open)
  judul          String                 @db.VarChar(200)
  deskripsi      String
  source         String                 @default("seed") @db.VarChar(50)
  entityType     String?                @map("entity_type") @db.VarChar(50)
  entityId       Int?                   @map("entity_id")
  wilayahLevel   String?                @map("wilayah_level") @db.VarChar(20)
  wilayahId      Int?                   @map("wilayah_id")
  metadata       Json                   @default("{}")
  createdBy      Int?                   @map("created_by")
  acknowledgedBy Int?                   @map("acknowledged_by")
  acknowledgedAt DateTime?              @map("acknowledged_at")
  resolvedBy     Int?                   @map("resolved_by")
  resolvedAt     DateTime?              @map("resolved_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  createdByUser      User? @relation("OperationalAlertCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  acknowledgedByUser User? @relation("OperationalAlertAcknowledgedBy", fields: [acknowledgedBy], references: [id], onDelete: SetNull)
  resolvedByUser     User? @relation("OperationalAlertResolvedBy", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
  @@index([kategori])
  @@index([entityType, entityId])
  @@index([wilayahLevel, wilayahId])
  @@index([createdAt(sort: Desc)])
  @@index([createdBy])
  @@index([acknowledgedBy])
  @@index([resolvedBy])
  @@map("operational_alerts")
}

// ── BANTUAN ──────────────────────────────────────────────────────

model Bantuan {
  id             Int       @id @default(autoincrement())
  nama           String    @db.VarChar(200)
  tipe           String    @db.VarChar(30)
  deskripsi      String?
  satuan         String    @default("paket") @db.VarChar(30)
  nilaiPerSatuan Float?    @map("nilai_per_satuan")
  stokTotal      Float     @default(0) @map("stok_total")
  stokTersisa    Float     @default(0) @map("stok_tersisa")
  sumber         String?   @db.VarChar(200)
  tanggalMasuk   DateTime? @map("tanggal_masuk")
  aktif          Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  penerima BantuanPenerima[]

  @@index([aktif])
  @@map("bantuan")
}

model BantuanPenerima {
  id              Int              @id @default(autoincrement())
  bantuanId       Int              @map("bantuan_id")
  keluargaId      Int?             @map("keluarga_id")
  namaPenerima    String           @map("nama_penerima") @db.VarChar(150)
  rtId            Int?             @map("rt_id")
  jumlahDiterima  Float            @map("jumlah_diterima")
  status          DistribusiStatus @default(terjadwal)
  tanggalDiterima DateTime?        @map("tanggal_diterima")
  buktiFotoUrl    String?          @map("bukti_foto_url")
  catatan         String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  bantuan  Bantuan   @relation(fields: [bantuanId], references: [id])
  keluarga Keluarga? @relation(fields: [keluargaId], references: [id], onDelete: SetNull)
  rt       RT?       @relation(fields: [rtId], references: [id], onDelete: SetNull)

  @@index([bantuanId])
  @@index([keluargaId])
  @@index([rtId])
  @@index([status])
  @@map("bantuan_penerima")
}

// ── WARMINDO ─────────────────────────────────────────────────────

model WarmindoOutlet {
  id                Int            @id @default(autoincrement())
  kodeOutlet        String         @unique @map("kode_outlet") @db.VarChar(20)
  namaOutlet        String         @map("nama_outlet") @db.VarChar(200)
  kelurahanId       Int?           @map("kelurahan_id")
  rtId              Int?           @map("rt_id")
  alamat            String?
  koordinatLat      Float?         @map("koordinat_lat")
  koordinatLng      Float?         @map("koordinat_lng")
  status            WarmindoStatus @default(rencana)
  modalAwal         Float          @default(0) @map("modal_awal")
  targetOmzetHarian Float          @default(0) @map("target_omzet_harian")
  targetLabaBulanan Float          @default(0) @map("target_laba_bulanan")
  biayaSewaBulanan  Float          @default(0) @map("biaya_sewa_bulanan")
  karyawanTotal     Int            @default(0) @map("karyawan_total")
  managerUserId     Int?           @map("manager_user_id")
  aktif             Boolean        @default(true)
  tanggalBuka       DateTime?      @map("tanggal_buka")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  kelurahan   Kelurahan?            @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  rt          RT?                   @relation(fields: [rtId], references: [id], onDelete: SetNull)
  manager     User?                 @relation("WarmindoOutletManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  users       User[]                @relation("UserWarmindoOutlet")
  inventory   WarmindoInventory[]
  transaksi   WarmindoTransaksi[]
  pengeluaran WarmindoPengeluaran[]

  @@index([status])
  @@index([aktif])
  @@index([kelurahanId])
  @@index([rtId])
  @@index([managerUserId])
  @@map("warmindo_outlet")
}

model WarmindoInventory {
  id          Int      @id @default(autoincrement())
  warmindoId  Int      @map("warmindo_id")
  namaBahan   String   @map("nama_bahan") @db.VarChar(200)
  satuan      String   @default("pcs") @db.VarChar(20)
  stokSaatIni Float    @default(0) @map("stok_saat_ini")
  stokMinimum Float    @default(0) @map("stok_minimum")
  hargaBeli   Float    @default(0) @map("harga_beli")
  hargaJual   Float    @default(0) @map("harga_jual")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  warmindo WarmindoOutlet @relation(fields: [warmindoId], references: [id])

  @@unique([warmindoId, namaBahan])
  @@index([warmindoId])
  @@map("warmindo_inventory")
}

model WarmindoTransaksi {
  id          Int      @id @default(autoincrement())
  warmindoId  Int      @map("warmindo_id")
  tanggal     DateTime @default(now())
  totalOmzet  Float    @default(0) @map("total_omzet")
  totalHpp    Float    @default(0) @map("total_hpp")
  grossProfit Float    @default(0) @map("gross_profit")
  jumlahItem  Int      @default(0) @map("jumlah_item")
  metodeBayar String   @default("tunai") @map("metode_bayar") @db.VarChar(20)
  items       Json     @default("[]")
  catatan     String?
  createdAt   DateTime @default(now()) @map("created_at")

  warmindo WarmindoOutlet @relation(fields: [warmindoId], references: [id])

  @@index([warmindoId, tanggal(sort: Desc)])
  @@index([tanggal(sort: Desc)])
  @@map("warmindo_transaksi")
}

model WarmindoPengeluaran {
  id         Int      @id @default(autoincrement())
  warmindoId Int      @map("warmindo_id")
  tanggal    DateTime @default(now())
  kategori   String   @db.VarChar(30)
  deskripsi  String   @db.VarChar(300)
  jumlah     Float
  createdAt  DateTime @default(now()) @map("created_at")

  warmindo WarmindoOutlet @relation(fields: [warmindoId], references: [id])

  @@index([warmindoId, tanggal(sort: Desc)])
  @@map("warmindo_pengeluaran")
}

// ── FILES ─────────────────────────────────────────────────────────

model File {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  originalName String   @map("original_name") @db.VarChar(255)
  storedName   String   @map("stored_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  sizeBytes    Int      @map("size_bytes")
  storagePath  String   @map("storage_path")
  isPublic     Boolean  @default(false) @map("is_public")
  entityType   String?  @map("entity_type") @db.VarChar(50)
  entityId     Int?     @map("entity_id")
  uploadedBy   Int?     @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  uploadedByUser User? @relation("FileUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@map("files")
}

// ── AI ENGINE ─────────────────────────────────────────────────────

model AiTask {
  id           Int          @id @default(autoincrement())
  tipe         String       @db.VarChar(50)
  inputData    Json         @map("input_data")
  outputData   Json?        @map("output_data")
  status       AiTaskStatus @default(pending)
  errorMessage String?      @map("error_message")
  modelUsed    String?      @map("model_used") @db.VarChar(50)
  createdBy    Int?         @map("created_by")
  startedAt    DateTime?    @map("started_at")
  doneAt       DateTime?    @map("done_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  createdByUser User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdBy])
  @@index([createdAt(sort: Desc)])
  @@map("ai_tasks")
}

model AiReport {
  id           Int      @id @default(autoincrement())
  tipe         String   @db.VarChar(50)
  wilayahLevel String?  @map("wilayah_level") @db.VarChar(20)
  wilayahId    Int?     @map("wilayah_id")
  tanggal      DateTime @default(now())
  ringkasan    String
  temuan       Json     @default("[]")
  rekomendasi  Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("ai_reports")
}

model DesignJob {
  id            Int          @id @default(autoincrement())
  tipe          String       @db.VarChar(30)
  platform      String       @db.VarChar(30)
  inputData     Json         @map("input_data")
  generatedText String?      @map("generated_text")
  status        AiTaskStatus @default(pending)
  createdBy     Int?         @map("created_by")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  createdByUser User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdBy])
  @@map("design_jobs")
}

model VideoJob {
  id        Int          @id @default(autoincrement())
  judul     String       @db.VarChar(200)
  script    String
  videoUrl  String?      @map("video_url")
  status    AiTaskStatus @default(pending)
  createdBy Int?         @map("created_by")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  createdByUser User? @relation("VideoJobCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdBy])
  @@map("video_jobs")
}

// ── TPS / QUICK COUNT ─────────────────────────────────────────────

model ElectionEvent {
  id               Int      @id @default(autoincrement())
  namaEvent        String   @map("nama_event") @db.VarChar(200)
  jenisEvent       String   @map("jenis_event") @db.VarChar(30)
  tanggalPemilihan DateTime @map("tanggal_pemilihan") @db.Date
  kecamatanId      Int?     @map("kecamatan_id")
  status           String   @default("persiapan") @db.VarChar(20)
  kontestan        Json     @default("[]")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  kecamatan Kecamatan?  @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  tps       Tps[]
  results   TpsResult[]

  @@index([kecamatanId])
  @@index([status])
  @@map("election_events")
}

model Tps {
  id          Int      @id @default(autoincrement())
  kodeTps     String   @map("kode_tps") @db.VarChar(20)
  electionId  Int      @map("election_id")
  rtId        Int?     @map("rt_id")
  kelurahanId Int?     @map("kelurahan_id")
  kecamatanId Int?     @map("kecamatan_id")
  alamat      String?
  jumlahDpt   Int      @default(0) @map("jumlah_dpt")
  createdAt   DateTime @default(now()) @map("created_at")

  election  ElectionEvent @relation(fields: [electionId], references: [id])
  rt        RT?           @relation(fields: [rtId], references: [id], onDelete: SetNull)
  kelurahan Kelurahan?    @relation(fields: [kelurahanId], references: [id], onDelete: SetNull)
  kecamatan Kecamatan?    @relation(fields: [kecamatanId], references: [id], onDelete: SetNull)
  results   TpsResult[]

  @@unique([electionId, kodeTps])
  @@index([electionId])
  @@index([rtId])
  @@index([kelurahanId])
  @@index([kecamatanId])
  @@map("tps")
}

model TpsResult {
  id             Int      @id @default(autoincrement())
  tpsId          Int      @map("tps_id")
  electionId     Int      @map("election_id")
  jumlahPengguna Int      @default(0) @map("jumlah_pengguna")
  suaraSah       Int      @default(0) @map("suara_sah")
  suaraTidakSah  Int      @default(0) @map("suara_tidak_sah")
  hasilSuara     Json     @default("{}") @map("hasil_suara")
  buktiFotoUrl   String?  @map("bukti_foto_url")
  status         String   @default("draft") @db.VarChar(20)
  inputBy        Int?     @map("input_by")
  verifiedBy     Int?     @map("verified_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tps          Tps           @relation(fields: [tpsId], references: [id])
  election     ElectionEvent @relation(fields: [electionId], references: [id])
  inputByUser  User?         @relation("TpsResultInputBy", fields: [inputBy], references: [id], onDelete: SetNull)
  verifiedUser User?         @relation("TpsResultVerifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)

  @@unique([tpsId, electionId])
  @@index([electionId])
  @@index([inputBy])
  @@index([verifiedBy])
  @@index([status])
  @@map("tps_results")
}

// ── PUBLIC OFFICIAL ───────────────────────────────────────────────

model PublicOfficial {
  id               Int      @id @default(autoincrement())
  namaLengkap      String   @map("nama_lengkap") @db.VarChar(200)
  gelarDepan       String?  @map("gelar_depan") @db.VarChar(50)
  gelarBelakang    String?  @map("gelar_belakang") @db.VarChar(100)
  officialPhotoUrl String?  @map("official_photo_url")
  jabatan          String   @db.VarChar(200)
  lembaga          String   @db.VarChar(200)
  fraksi           String?  @db.VarChar(100)
  partai           String?  @db.VarChar(100)
  komisi           String?  @db.VarChar(100)
  dapil            String?  @db.VarChar(200)
  periode          String?  @db.VarChar(50)
  fokusKomisi      String[] @default([]) @map("fokus_komisi")
  waAspirasi       String?  @map("wa_aspirasi") @db.VarChar(20)
  instagram        String?  @db.VarChar(100)
  bioSingkat       String?  @map("bio_singkat")
  visi             String?
  misi             String[] @default([])
  aktif            Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  aspirasi OfficialAspirasi[]

  @@index([aktif])
  @@index([lembaga])
  @@map("public_officials")
}

model OfficialAspirasi {
  id            Int      @id @default(autoincrement())
  officialId    Int      @map("official_id")
  namaPelapor   String?  @map("nama_pelapor") @db.VarChar(150)
  noHp          String?  @db.VarChar(20)
  wilayah       String?  @db.VarChar(200)
  judulAspirasi String   @map("judul_aspirasi") @db.VarChar(300)
  isiAspirasi   String   @map("isi_aspirasi")
  kategori      String?  @db.VarChar(50)
  status        String   @default("diterima") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  official PublicOfficial @relation(fields: [officialId], references: [id])

  @@index([officialId])
  @@index([status])
  @@map("official_aspirasi")
}
