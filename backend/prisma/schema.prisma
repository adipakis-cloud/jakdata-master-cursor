  claim            String
  territoryLevel   TerritoryLevel?      @map("territory_level")
  territoryId      Int?                 @map("territory_id")
  method           CausalInferenceMethod
  confidence       Float                @default(0.5)
  evidenceSummary  String?              @map("evidence_summary") @db.VarChar(600)
  repeatCount      Int                  @default(1) @map("repeat_count")
  createdAt        DateTime             @default(now()) @map("created_at")

  @@index([territoryLevel, territoryId])
  @@map("ai_causal_inference")
}

model DataConfidenceRecord {
  id              Int            @id @default(autoincrement())
  subjectType     String         @map("subject_type") @db.VarChar(50)
  subjectId       Int            @map("subject_id")
  territoryLevel  TerritoryLevel? @map("territory_level")
  territoryId     Int?           @map("territory_id")
  completeness    Float          @default(0)
  validity        Float          @default(0)
  trustScore      Float          @default(0) @map("trust_score")
  conflictFlags   String[]       @map("conflict_flags")
  modelVersion    String         @default("v1") @map("model_version") @db.VarChar(20)
  computedAt      DateTime       @default(now()) @map("computed_at")

  @@index([subjectType, subjectId])
  @@map("data_confidence_record")
}
