generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin_pusat
  koordinator_kecamatan
  koordinator_kelurahan
  koordinator_rw
  koordinator_rt
  petugas_lapangan
  manager_warmindo
  kasir_warmindo
  auditor
  finance_admin
}

