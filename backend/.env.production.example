# ================================================
# JAKDATA BACKEND — PRODUCTION ENVIRONMENT
# Copy to .env and fill in real values
# NEVER commit .env to git
# ================================================

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/jakdata_prod?schema=public&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/jakdata_prod?schema=public&sslmode=require"

# JWT — MUST be changed from default
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_RANDOM_64_CHAR_HEX_STRING"
JWT_EXPIRES_IN="7d"

# Server
NODE_ENV="production"
PORT=3001
HOST="0.0.0.0"

# Frontend URL for CORS (your actual domain)
FRONTEND_URL="https://jakdata.yourdomain.com"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Rate Limiting (production values)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Optional: Supabase (if using Supabase instead of local PG)
# SUPABASE_URL="https://xxx.supabase.co"
# SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_KEY="eyJ..."

# Optional: AI / integrations (wajib untuk balasan WA/Email AI)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# REDIS_HOST=localhost
# REDIS_PORT=6379
# ENABLE_AI_WORKERS=true

# WhatsApp AI (Baileys — scan QR on first run)
# WA_PHONE_NUMBER=08xxxxxxxxxx

# Email AI (Gmail App Password, not account password)
# EMAIL_USER=your@gmail.com
# EMAIL_PASSWORD="xxxx xxxx xxxx xxxx"
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# Optional: Prisma pool hints (see src/config/prisma.ts)
# PRISMA_CONNECTION_LIMIT=5
# PRISMA_POOL_TIMEOUT=60
