# JAKDATA local/Supabase runtime environment
# Copy to backend/.env for local backend and Prisma commands.

# Prisma application connection.
# Local PostgreSQL example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jakdata?schema=public"
# Supabase pooled example:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL=""

# Prisma migration/direct connection.
# For local PostgreSQL this can match DATABASE_URL.
# For Supabase use the direct database host, not the transaction pooler.
# DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?schema=public"
DIRECT_URL=""

# Backend JWT signing secret. Use a long random value in every environment.
JWT_SECRET=""

# Supabase project settings for services that need Supabase APIs.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
