// ================================================================
// JAKDATA — Prisma Schema
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ────────────────────────────────────────────────────────

enum UserRole {
  admin_pusat
  koordinator_kecamatan
  koordinator_kelurahan
  koordinator_rw
  koordinator_rt
  petugas_lapangan
  manager_warmindo
  kasir_warmindo
  auditor
  finance_admin
}

enum StatusEkonomi {
  sangat_miskin
  miskin
  rentan
  sedang
  mampu
}

enum UrgencyLevel {
  critical
  high
  medium
  low
}

enum ReportStatus {
  baru
  diproses
  menunggu_data
  eskalasi
  selesai
  ditolak
}

enum WarmindoStatus {
  rencana
  persiapan
  aktif
  evaluasi
  tutup
}

enum AiTaskStatus {
  pending
  processing
  done
  failed
}

// ── USERS ────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  uuid         String    @unique @default(uuid())
  nama         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         UserRole
  aktif        Boolean   @default(true)
  noHp         String?   @map("no_hp")
  lastLoginAt  DateTime? @map("last_login_at")

  // Territory scope (null = semua wilayah untuk admin)
  kecamatanId Int? @map("kecamatan_id")
  kelurahanId Int? @map("kelurahan_id")
  rwId        Int? @map("rw_id")
  rtId        Int? @map("rt_id")
  warmindoId  Int? @map("warmindo_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  kecamatan     Kecamatan?      @relation(fields: [kecamatanId], references: [id])
  kelurahan     Kelurahan?      @relation(fields: [kelurahanId], references: [id])
  rw            RW?             @relation(fields: [rwId], references: [id])
  rt            RT?             @relation(fields: [rtId], references: [id])
  laporanWarga  LaporanWarga[]
  aiTasks       AiTask[]
  designJobs    DesignJob[]

  @@map("users")
}

// ── WILAYAH ──────────────────────────────────────────────────────

model Provinsi {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  kode      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  kota      Kota[]

  @@map("provinsi")
}

model Kota {
  id          Int        @id @default(autoincrement())
  provinsiId  Int        @map("provinsi_id")
  nama        String
  kode        String     @unique
  createdAt   DateTime   @default(now()) @map("created_at")
  provinsi    Provinsi   @relation(fields: [provinsiId], references: [id])
  kecamatan   Kecamatan[]

  @@unique([provinsiId, nama])
  @@map("kota")
}

model Kecamatan {
  id        Int         @id @default(autoincrement())
  kotaId    Int         @map("kota_id")
  nama      String
  kode      String?
  createdAt DateTime    @default(now()) @map("created_at")
  kota      Kota        @relation(fields: [kotaId], references: [id])
  kelurahan Kelurahan[]
  users     User[]

  @@unique([kotaId, nama])
  @@map("kecamatan")
}

model Kelurahan {
  id           Int       @id @default(autoincrement())
  kecamatanId  Int       @map("kecamatan_id")
  nama         String
  kode         String?
  kodePos      String?   @map("kode_pos")
  createdAt    DateTime  @default(now()) @map("created_at")
  kecamatan    Kecamatan @relation(fields: [kecamatanId], references: [id])
  rw           RW[]
  users        User[]

  @@unique([kecamatanId, nama])
  @@map("kelurahan")
}

model RW {
  id           Int       @id @default(autoincrement())
  kelurahanId  Int       @map("kelurahan_id")
  nomor        String
  namaKetua    String?   @map("nama_ketua")
  noHpKetua    String?   @map("no_hp_ketua")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  kelurahan    Kelurahan @relation(fields: [kelurahanId], references: [id])
  rt           RT[]
  users        User[]

  @@unique([kelurahanId, nomor])
  @@map("rw")
}

model RT {
  id          Int      @id @default(autoincrement())
  rwId        Int      @map("rw_id")
  nomor       String
  namaKetua   String?  @map("nama_ketua")
  noHpKetua   String?  @map("no_hp_ketua")
  jumlahKk    Int      @default(0) @map("jumlah_kk")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  rw          RW       @relation(fields: [rwId], references: [id])
  warga       Warga[]
  keluarga    Keluarga[]
  users       User[]

  @@unique([rwId, nomor])
  @@map("rt")
}

// ── WARGA ────────────────────────────────────────────────────────

model Warga {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  rtId             Int           @map("rt_id")
  nama             String
  noHp             String?       @map("no_hp")
  jenisKelamin     String?       @map("jenis_kelamin")
  tanggalLahir     DateTime?     @map("tanggal_lahir")
  alamat           String?
  pekerjaan        String?
  penghasilanEst   Float?        @map("penghasilan_est")
  statusEkonomi    StatusEkonomi? @map("status_ekonomi")
  kemampuanKerja   Boolean       @default(true) @map("kemampuan_kerja")
  kebutuhanKhusus  String?       @map("kebutuhan_khusus")
  kategori         String        @default("warga_biasa")
  // warga_biasa, ketua_rt, ketua_rw, koordinator, penerima_bantuan, pekerja_warmindo
  diverifikasi     Boolean       @default(false)
  catatan          String?
  fotoUrl          String?       @map("foto_url")
  kkId             Int?          @map("kk_id")
  createdBy        Int?          @map("created_by")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  rt               RT            @relation(fields: [rtId], references: [id])
  keluarga         Keluarga?     @relation(fields: [kkId], references: [id])

  @@map("warga")
}

model Keluarga {
  id                Int           @id @default(autoincrement())
  rtId              Int           @map("rt_id")
  namaKepala        String        @map("nama_kepala")
  noKk              String?       @unique @map("no_kk")
  noHpKepala        String?       @map("no_hp_kepala")
  jumlahAnggota     Int           @default(1) @map("jumlah_anggota")
  jumlahTanggungan  Int           @default(0) @map("jumlah_tanggungan")
  statusRumah       String?       @map("status_rumah")
  statusEkonomi     StatusEkonomi? @map("status_ekonomi")
  totalPenghasilan  Float?        @map("total_penghasilan")
  skorPrioritasBantuan Float?     @map("skor_prioritas_bantuan")
  kategoriBAntuan   String        @default("normal") @map("kategori_bantuan")
  terdaftarProgramLain String[]   @map("terdaftar_program_lain")
  catatan           String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  rt                RT            @relation(fields: [rtId], references: [id])
  warga             Warga[]
  bantuanPenerima   BantuanPenerima[]

  @@map("keluarga")
}

// ── LAPORAN WARGA ────────────────────────────────────────────────

model LaporanWarga {
  id                  Int          @id @default(autoincrement())
  kodeLaporan         String       @unique @map("kode_laporan")
  channelType         String       @map("channel_type") // whatsapp,email,web,koordinator
  namaPelapor         String?      @map("nama_pelapor")
  noHpPelapor         String?      @map("no_hp_pelapor")
  isiLaporan          String       @map("isi_laporan")
  kategori            String       // bencana,sosial,pendidikan,kesehatan,ekonomi,bantuan
  subkategori         String?
  urgencyLevel        UrgencyLevel @default(medium) @map("urgency_level")
  lokasiText          String?      @map("lokasi_text")
  rtId                Int?         @map("rt_id")
  kelurahanId         Int?         @map("kelurahan_id")
  kecamatanId         Int?         @map("kecamatan_id")
  isEmergency         Boolean      @default(false) @map("is_emergency")
  status              ReportStatus @default(baru)
  aiSummary           String?      @map("ai_summary")
  aiRecommendation    String?      @map("ai_recommendation")
  lampiranUrls        String[]     @map("lampiran_urls")
  assignedTo          Int?         @map("assigned_to")
  slaDeadline         DateTime?    @map("sla_deadline")
  resolvedAt          DateTime?    @map("resolved_at")
  createdBy           Int?         @map("created_by")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  createdByUser       User?        @relation(fields: [createdBy], references: [id])
  messages            LaporanMessage[]

  @@map("laporan_warga")
}

model LaporanMessage {
  id          Int          @id @default(autoincrement())
  laporanId   Int          @map("laporan_id")
  senderType  String       @map("sender_type") // warga,ai,admin,koordinator
  messageText String       @map("message_text")
  attachmentUrls String[]  @map("attachment_urls")
  isInternal  Boolean      @default(false) @map("is_internal")
  createdAt   DateTime     @default(now()) @map("created_at")

  laporan     LaporanWarga @relation(fields: [laporanId], references: [id])

  @@map("laporan_messages")
}

// ── BANTUAN ──────────────────────────────────────────────────────

model Bantuan {
  id           Int      @id @default(autoincrement())
  nama         String
  tipe         String   // sembako,uang,voucher,kesehatan,modal,pelatihan
  deskripsi    String?
  satuan       String   @default("paket")
  nilaiPerSatuan Float? @map("nilai_per_satuan")
  stokTotal    Float    @default(0) @map("stok_total")
  stokTersisa  Float    @default(0) @map("stok_tersisa")
  sumber       String?
  tanggalMasuk DateTime? @map("tanggal_masuk")
  aktif        Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  penerima     BantuanPenerima[]

  @@map("bantuan")
}

model BantuanPenerima {
  id               Int      @id @default(autoincrement())
  bantuanId        Int      @map("bantuan_id")
  keluargaId       Int?     @map("keluarga_id")
  namaPenerima     String   @map("nama_penerima")
  rtId             Int?     @map("rt_id")
  jumlahDiterima   Float    @map("jumlah_diterima")
  status           String   @default("terjadwal")
  tanggalDiterima  DateTime? @map("tanggal_diterima")
  buktiFotoUrl     String?  @map("bukti_foto_url")
  createdAt        DateTime @default(now()) @map("created_at")

  bantuan          Bantuan  @relation(fields: [bantuanId], references: [id])
  keluarga         Keluarga? @relation(fields: [keluargaId], references: [id])

  @@map("bantuan_penerima")
}

// ── WARMINDO ─────────────────────────────────────────────────────

model WarmindoOutlet {
  id              Int            @id @default(autoincrement())
  kodeOutlet      String         @unique @map("kode_outlet")
  namaOutlet      String         @map("nama_outlet")
  kelurahanId     Int?           @map("kelurahan_id")
  rtId            Int?           @map("rt_id")
  alamat          String?
  status          WarmindoStatus @default(rencana)
  modalAwal       Float          @default(0) @map("modal_awal")
  targetOmzetHarian Float        @default(0) @map("target_omzet_harian")
  targetLabaBulanan Float        @default(0) @map("target_laba_bulanan")
  biayaSewaBulanan Float         @default(0) @map("biaya_sewa_bulanan")
  karyawanTotal   Int            @default(0) @map("karyawan_total")
  managerUserId   Int?           @map("manager_user_id")
  aktif           Boolean        @default(true)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  inventory       WarmindoInventory[]
  transaksi       WarmindoTransaksi[]
  pengeluaran     WarmindoPengeluaran[]

  @@map("warmindo_outlet")
}

model WarmindoInventory {
  id              Int            @id @default(autoincrement())
  warmindoId      Int            @map("warmindo_id")
  namaBahan       String         @map("nama_bahan")
  satuan          String         @default("pcs")
  stokSaatIni     Float          @default(0) @map("stok_saat_ini")
  stokMinimum     Float          @default(0) @map("stok_minimum")
  hargaBeli       Float          @default(0) @map("harga_beli")
  hargaJual       Float          @default(0) @map("harga_jual")
  supplierUtama   String?        @map("supplier_utama")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  warmindo        WarmindoOutlet @relation(fields: [warmindoId], references: [id])

  @@unique([warmindoId, namaBahan])
  @@map("warmindo_inventory")
}

model WarmindoTransaksi {
  id            Int            @id @default(autoincrement())
  warmindoId    Int            @map("warmindo_id")
  tanggal       DateTime       @default(now())
  totalOmzet    Float          @default(0) @map("total_omzet")
  totalHpp      Float          @default(0) @map("total_hpp")
  grossProfit   Float          @default(0) @map("gross_profit")
  jumlahItem    Int            @default(0) @map("jumlah_item")
  metodeBayar   String         @default("tunai") @map("metode_bayar")
  items         Json           @default("[]") // array item detail
  catatan       String?
  kasirId       Int?           @map("kasir_id")
  createdAt     DateTime       @default(now()) @map("created_at")

  warmindo      WarmindoOutlet @relation(fields: [warmindoId], references: [id])

  @@map("warmindo_transaksi")
}

model WarmindoPengeluaran {
  id          Int            @id @default(autoincrement())
  warmindoId  Int            @map("warmindo_id")
  tanggal     DateTime       @default(now())
  kategori    String         // bahan_baku,gaji,sewa,listrik,lain
  deskripsi   String
  jumlah      Float
  buktiFoto   String?        @map("bukti_foto")
  createdAt   DateTime       @default(now()) @map("created_at")

  warmindo    WarmindoOutlet @relation(fields: [warmindoId], references: [id])

  @@map("warmindo_pengeluaran")
}

// ── TPS ──────────────────────────────────────────────────────────

model Tps {
  id          Int    @id @default(autoincrement())
  kodeTps     String @map("kode_tps")
  rtId        Int?   @map("rt_id")
  kelurahanId Int?   @map("kelurahan_id")
  kecamatanId Int?   @map("kecamatan_id")
  alamat      String?
  jumlahDpt   Int    @default(0) @map("jumlah_dpt")
  createdAt   DateTime @default(now()) @map("created_at")
  results     TpsResult[]

  @@map("tps")
}

model TpsResult {
  id           Int      @id @default(autoincrement())
  tpsId        Int      @map("tps_id")
  electionId   String   @map("election_id")
  jumlahPengguna Int    @default(0) @map("jumlah_pengguna")
  suaraSah     Int      @default(0) @map("suara_sah")
  suaraTidakSah Int     @default(0) @map("suara_tidak_sah")
  hasilSuara   Json     @default("{}") @map("hasil_suara")
  buktiFotoUrl String?  @map("bukti_foto_url")
  status       String   @default("draft")
  inputBy      Int?     @map("input_by")
  verifiedBy   Int?     @map("verified_by")
  createdAt    DateTime @default(now()) @map("created_at")

  tps          Tps      @relation(fields: [tpsId], references: [id])

  @@unique([tpsId, electionId])
  @@map("tps_results")
}

// ── AI ENGINE ────────────────────────────────────────────────────

model AiTask {
  id           Int         @id @default(autoincrement())
  tipe         String      // classify_report,score_bantuan,analyze_warmindo,generate_content
  inputData    Json        @map("input_data")
  outputData   Json?       @map("output_data")
  status       AiTaskStatus @default(pending)
  errorMessage String?     @map("error_message")
  modelUsed    String?     @map("model_used")
  createdBy    Int?        @map("created_by")
  startedAt    DateTime?   @map("started_at")
  doneAt       DateTime?   @map("done_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  createdByUser User?      @relation(fields: [createdBy], references: [id])

  @@map("ai_tasks")
}

model AiReport {
  id            Int      @id @default(autoincrement())
  tipe          String   // daily_wilayah,daily_warmindo,bantuan_priority
  wilayahLevel  String?  @map("wilayah_level")
  wilayahId     Int?     @map("wilayah_id")
  tanggal       DateTime @default(now())
  ringkasan     String
  temuan        Json     @default("[]")
  rekomendasi   Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("ai_reports")
}

model DesignJob {
  id              Int          @id @default(autoincrement())
  tipe            String       // caption,poster,script,broadcast
  platform        String       // instagram,tiktok,whatsapp,poster
  inputData       Json         @map("input_data")
  generatedText   String?      @map("generated_text")
  generatedFileUrl String?     @map("generated_file_url")
  status          AiTaskStatus @default(pending)
  createdBy       Int?         @map("created_by")
  createdAt       DateTime     @default(now()) @map("created_at")

  createdByUser   User?        @relation(fields: [createdBy], references: [id])

  @@map("design_jobs")
}

model VideoJob {
  id           Int          @id @default(autoincrement())
  judul        String
  script       String
  heygenJobId  String?      @map("heygen_job_id")
  videoUrl     String?      @map("video_url")
  status       AiTaskStatus @default(pending)
  createdBy    Int?         @map("created_by")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("video_jobs")
}
